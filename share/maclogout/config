# maclogout configuration
# Format: KEY=VALUE, lines starting with # are comments

# Hour to start the logout window (0-23)
START_HOUR=22

# Hour to end the logout window (0-23)
# When END_HOUR < START_HOUR, the window wraps past midnight (e.g. 22→5)
END_HOUR=5

# Path to log file
LOG_FILE=/var/log/maclogout.log
