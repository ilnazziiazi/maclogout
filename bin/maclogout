#!/bin/bash
#
# maclogout — lock screen during configured nighttime window
# Runs as LaunchDaemon every 60 seconds as root.
#

set -euo pipefail

VERSION="1.0.0"
CONFIG_FILE="@@HOMEBREW_ETC@@/maclogout/config"
LOG_FILE="/var/log/maclogout.log"

# ── Flag handling ──────────────────────────────────────

usage() {
    echo "maclogout — lock screen during configured nighttime window"
    echo ""
    echo "Usage:"
    echo "  maclogout                  Run a check tick (called by daemon)"
    echo "  maclogout --show           Show current configuration"
    echo "  maclogout --start <hour>   Set START_HOUR (requires sudo)"
    echo "  maclogout --end <hour>     Set END_HOUR (requires sudo)"
    echo "  maclogout --path           Show config file path"
    echo "  maclogout --version        Print version"
    echo "  maclogout --help           This help"
    echo ""
    echo "Config: $CONFIG_FILE"
}

set_config_key() {
    local key="$1" val="$2"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo "Config file not found: $CONFIG_FILE" >&2
        exit 1
    fi
    tmp=$(mktemp)
    awk -v k="$key" -v v="$val" '
        $0 ~ "^[[:space:]]*" k "[[:space:]]*=" { print k "=" v; found=1; next }
        { print }
        END { if (!found) print k "=" v }
    ' "$CONFIG_FILE" > "$tmp"
    mv "$tmp" "$CONFIG_FILE"
    echo "$key = $val"
}

changed=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version)
            echo "maclogout $VERSION"
            exit 0
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --show)
            if [[ ! -f "$CONFIG_FILE" ]]; then
                echo "Config file not found: $CONFIG_FILE" >&2
                exit 1
            fi
            cat "$CONFIG_FILE"
            exit 0
            ;;
        --path)
            echo "$CONFIG_FILE"
            exit 0
            ;;
        --start)
            if [[ -z "${2:-}" ]]; then
                echo "Usage: maclogout --start <0-23>" >&2
                exit 1
            fi
            set_config_key START_HOUR "$2"
            changed=true
            shift 2
            ;;
        --end)
            if [[ -z "${2:-}" ]]; then
                echo "Usage: maclogout --end <0-23>" >&2
                exit 1
            fi
            set_config_key END_HOUR "$2"
            changed=true
            shift 2
            ;;
        *)
            echo "maclogout: unknown option '$1'. Try --help." >&2
            exit 1
            ;;
    esac
done

$changed && exit 0

# ── Functions ──────────────────────────────────────────

log_msg() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        log_msg "ERROR: config not found at $CONFIG_FILE"
        exit 1
    fi
    set -a
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
    set +a

    if [[ -z "${START_HOUR:-}" ]] || [[ -z "${END_HOUR:-}" ]]; then
        log_msg "ERROR: START_HOUR or END_HOUR not set in config"
        exit 1
    fi

    if ! [[ "$START_HOUR" =~ ^[0-9]+$ ]] || [[ "$START_HOUR" -gt 23 ]]; then
        log_msg "ERROR: START_HOUR must be 0-23, got '$START_HOUR'"
        exit 1
    fi

    if ! [[ "$END_HOUR" =~ ^[0-9]+$ ]] || [[ "$END_HOUR" -gt 23 ]]; then
        log_msg "ERROR: END_HOUR must be 0-23, got '$END_HOUR'"
        exit 1
    fi
}

is_in_logout_window() {
    local hour
    hour=$(date +%H)
    hour=$((10#$hour))  # strip leading zero (bash octal trap)

    if [[ "$START_HOUR" -lt "$END_HOUR" ]]; then
        # Normal range, e.g. 9–17
        [[ "$hour" -ge "$START_HOUR" && "$hour" -lt "$END_HOUR" ]] && return 0
    else
        # Wraps past midnight, e.g. 22–5
        [[ "$hour" -ge "$START_HOUR" || "$hour" -lt "$END_HOUR" ]] && return 0
    fi

    return 1
}

get_console_user() {
    /usr/bin/stat -f "%Su" /dev/console 2>/dev/null
}

lock_screen() {
    local console_user="$1"
    local uid

    uid=$(/usr/bin/id -u "$console_user" 2>/dev/null) || return 1

    if [[ "$uid" -eq 0 ]]; then
        return 0  # root on console — don't touch
    fi

    log_msg "Locking screen for user '$console_user' (uid=$uid)"

    # CGSession -suspend = Lock Screen (Ctrl+Cmd+Q equivalent)
    # Keeps all apps running, shows login screen
    if /bin/launchctl asuser "$uid" \
        /System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend 2>/dev/null; then
        log_msg "Screen locked via CGSession -suspend"
        return 0
    fi

    # Fallback: put displays to sleep (triggers lock if password is required)
    log_msg "CGSession failed, trying pmset displaysleepnow"
    if /usr/bin/pmset displaysleepnow 2>/dev/null; then
        log_msg "Screen locked via pmset displaysleepnow"
        return 0
    fi

    log_msg "WARNING: all lock methods failed for user '$console_user'"
    return 1
}

# ── Main ───────────────────────────────────────────────

if [[ "$(id -u)" -ne 0 ]]; then
    echo "maclogout: must run as root. Re-running with sudo..." >&2
    exec sudo "$0" "$@"
fi

log_msg "=== maclogout tick ==="
load_config

if is_in_logout_window; then
    log_msg "Inside logout window (${START_HOUR}:00–${END_HOUR}:00)"

    console_user=$(get_console_user)

    if [[ -z "$console_user" ]] || [[ "$console_user" == "root" ]]; then
        log_msg "No GUI user on console, nothing to do"
        exit 0
    fi

    log_msg "Console user: $console_user"
    lock_screen "$console_user"
else
    log_msg "Outside logout window, nothing to do"
fi
